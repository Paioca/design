{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "RevTrue Design Tokens — W3C Design Tokens format (DTCG draft).",
  "color": {
    "brand": {
      "rev":   { "$value": "#F15A24", "$type": "color", "$description": "Primary orange — energy, action" },
      "true":  { "$value": "#2F3E47", "$type": "color", "$description": "Primary charcoal — confidence, professionalism" }
    },
    "rev": {
      "50":  { "$value": "#FEF3EE", "$type": "color" },
      "100": { "$value": "#FDE3D5", "$type": "color" },
      "200": { "$value": "#FAC1A1", "$type": "color" },
      "300": { "$value": "#F69466", "$type": "color" },
      "400": { "$value": "#F37A45", "$type": "color" },
      "500": { "$value": "#F15A24", "$type": "color" },
      "600": { "$value": "#D9430F", "$type": "color" },
      "700": { "$value": "#B5340D", "$type": "color" },
      "800": { "$value": "#912A11", "$type": "color" },
      "900": { "$value": "#762512", "$type": "color" },
      "950": { "$value": "#401007", "$type": "color" }
    },
    "true": {
      "50":  { "$value": "#F5F7F8", "$type": "color" },
      "100": { "$value": "#E7ECEE", "$type": "color" },
      "200": { "$value": "#D0D8DD", "$type": "color" },
      "300": { "$value": "#A8B7BF", "$type": "color" },
      "400": { "$value": "#7A8E99", "$type": "color" },
      "500": { "$value": "#5C7280", "$type": "color" },
      "600": { "$value": "#4A5C68", "$type": "color" },
      "700": { "$value": "#3D4B55", "$type": "color" },
      "800": { "$value": "#2F3E47", "$type": "color" },
      "900": { "$value": "#21303A", "$type": "color" },
      "950": { "$value": "#131D24", "$type": "color" }
    },
    "neutral": {
      "white": { "$value": "#FFFFFF", "$type": "color" },
      "black": { "$value": "#000000", "$type": "color" }
    },
    "semantic": {
      "background":         { "$value": "{color.neutral.white}",   "$type": "color" },
      "background-subtle":  { "$value": "{color.true.50}",         "$type": "color" },
      "foreground":         { "$value": "{color.true.900}",        "$type": "color" },
      "foreground-subtle":  { "$value": "{color.true.600}",        "$type": "color" },
      "border":             { "$value": "{color.true.200}",        "$type": "color" },
      "primary":            { "$value": "{color.brand.rev}",       "$type": "color" },
      "primary-hover":      { "$value": "{color.rev.600}",         "$type": "color" },
      "primary-active":     { "$value": "{color.rev.700}",         "$type": "color" },
      "on-primary":         { "$value": "{color.neutral.white}",   "$type": "color" }
    }
  },
  "font": {
    "family": {
      "display":   { "$value": "Hongkong, system-ui, sans-serif",        "$type": "fontFamily", "$description": "Display / headings" },
      "sans":      { "$value": "Roboto, system-ui, sans-serif",          "$type": "fontFamily", "$description": "Body / UI" },
      "condensed": { "$value": "Roboto Condensed, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "hairline": { "$value": 100, "$type": "fontWeight" },
      "thin":     { "$value": 200, "$type": "fontWeight" },
      "light":    { "$value": 300, "$type": "fontWeight" },
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "black":    { "$value": 900, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension" },
      "sm":   { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem",     "$type": "dimension" },
      "lg":   { "$value": "1.125rem", "$type": "dimension" },
      "xl":   { "$value": "1.25rem",  "$type": "dimension" },
      "2xl":  { "$value": "1.5rem",   "$type": "dimension" },
      "3xl":  { "$value": "1.875rem", "$type": "dimension" },
      "4xl":  { "$value": "2.25rem",  "$type": "dimension" },
      "5xl":  { "$value": "3rem",     "$type": "dimension" },
      "6xl":  { "$value": "3.75rem",  "$type": "dimension" },
      "7xl":  { "$value": "4.5rem",   "$type": "dimension" },
      "8xl":  { "$value": "6rem",     "$type": "dimension" },
      "9xl":  { "$value": "8rem",     "$type": "dimension" }
    }
  },
  "spacing": {
    "0":  { "$value": "0",       "$type": "dimension" },
    "1":  { "$value": "0.25rem", "$type": "dimension" },
    "2":  { "$value": "0.5rem",  "$type": "dimension" },
    "3":  { "$value": "0.75rem", "$type": "dimension" },
    "4":  { "$value": "1rem",    "$type": "dimension" },
    "6":  { "$value": "1.5rem",  "$type": "dimension" },
    "8":  { "$value": "2rem",    "$type": "dimension" },
    "12": { "$value": "3rem",    "$type": "dimension" },
    "16": { "$value": "4rem",    "$type": "dimension" },
    "24": { "$value": "6rem",    "$type": "dimension" },
    "32": { "$value": "8rem",    "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0",       "$type": "dimension" },
    "sm":   { "$value": "0.25rem", "$type": "dimension" },
    "md":   { "$value": "0.5rem",  "$type": "dimension" },
    "lg":   { "$value": "0.75rem", "$type": "dimension" },
    "xl":   { "$value": "1rem",    "$type": "dimension" },
    "2xl":  { "$value": "1.5rem",  "$type": "dimension" },
    "3xl":  { "$value": "2rem",    "$type": "dimension" },
    "full": { "$value": "9999px",  "$type": "dimension" }
  },
  "shadow": {
    "sm":  { "$value": "0 1px 2px 0 rgb(47 62 71 / 0.05)",                                          "$type": "shadow" },
    "md":  { "$value": "0 4px 6px -1px rgb(47 62 71 / 0.10), 0 2px 4px -2px rgb(47 62 71 / 0.10)",  "$type": "shadow" },
    "lg":  { "$value": "0 10px 15px -3px rgb(47 62 71 / 0.10), 0 4px 6px -4px rgb(47 62 71 / 0.10)", "$type": "shadow" },
    "xl":  { "$value": "0 20px 25px -5px rgb(47 62 71 / 0.10), 0 8px 10px -6px rgb(47 62 71 / 0.10)", "$type": "shadow" },
    "glow":{ "$value": "0 0 0 4px rgb(241 90 36 / 0.20)",                                            "$type": "shadow" }
  },
  "motion": {
    "duration": {
      "fast":  { "$value": "150ms", "$type": "duration" },
      "base":  { "$value": "250ms", "$type": "duration" },
      "slow":  { "$value": "400ms", "$type": "duration" }
    },
    "easing": {
      "rev-out": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" }
    }
  }
}
